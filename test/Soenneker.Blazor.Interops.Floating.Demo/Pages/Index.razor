@page "/"
@using System.Threading.Tasks
@using Soenneker.Blazor.Interops.Floating.Abstract

@inject IFloatingUiInterop Floating

<PageTitle>Soenneker.Blazor.Interops.Floating Demo</PageTitle>

<Div Space="Space.Y.Is4">
    <Paragraph TextSize="TextSize.Sm" Class="text-muted-foreground">
        Replace this page with package-specific demos. Initialization runs on first render below.
    </Paragraph>
</Div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await Floating.Initialize();
    }
}
